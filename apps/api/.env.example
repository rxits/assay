# Neon pooled connection string (?sslmode=require). Required.
DATABASE_URL=
# Optional — unset ⇒ classification runs regex-only (graceful, 00-SPEC §8).
# Server-side only; never commit a real key.
ANTHROPIC_API_KEY=
PORT=4000
NODE_ENV=development
# Web origin allowed by CORS (Vite dev default below).
CORS_ORIGIN=http://localhost:5173
