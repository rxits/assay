# Required. The value below matches the local Docker Postgres in the README's setup steps,
# so a fresh clone runs as-is. In production this is the Neon *pooled* connection string
# (host contains `-pooler`, plus ?sslmode=require) and is set in the host's env panel.
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/assay
# Optional — unset ⇒ classification runs regex-only (graceful, 00-SPEC §8).
# Server-side only; never commit a real key. Get one at https://console.groq.com/keys
GROQ_API_KEY=
# Optional overrides for the OpenAI-compatible LLM endpoint. Defaults shown.
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
PORT=4000
NODE_ENV=development
# Largest accepted upload, in MB. Default 100. Lower it on a memory-constrained host —
# parsing is in-memory, so this is the guard against a single upload exhausting the dyno.
MAX_UPLOAD_MB=100
# Comma-separated list of web origins allowed by CORS — normally just the one deployed
# frontend. No trailing slash; the value is matched against the browser's Origin header.
# Unset in development ⇒ falls back to the Vite dev origin below.
# Unset in production ⇒ no cross-origin caller is trusted. (cors() treats an undefined
# origin as `*`, so failing closed here is what stops a forgotten variable from quietly
# publishing the API to every site on the internet.)
CORS_ORIGIN=http://localhost:5173
# Shared secret for destructive routes — PATCH/POST /api/settings/* and everything under
# /api/data. Sent by the web app as the `x-admin-token` header; compared in constant time.
# Generate with: openssl rand -hex 32
# Unset in development ⇒ those routes are open (convenient locally, logged at boot).
# Unset in production ⇒ those routes are DISABLED (403), so a public demo cannot be wiped.
# Reads, uploads and classification overrides are never gated.
ADMIN_TOKEN=
